PORT=5000
MONGO_URI=mongodb://localhost:27017/hr-agent
JWT_SECRET=replace-with-your-secret
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_DEBUG=false
GEMINI_DEBUG_TEXT_LIMIT=1200
# true = đọc lại server/src/prompts/cv-evaluation.md mỗi request (tiện chỉnh prompt khi debug)
GEMINI_PROMPT_HOT_RELOAD=false
ANALYZE_EMAIL_DEBUG=true
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
CLIENT_URL=http://localhost:5173/login
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.compose https://www.googleapis.com/auth/gmail.send
