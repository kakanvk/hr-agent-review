# Docker environment variables
# Copy this file to .env.local or .env and update with your actual values

# Server
PORT=5000
MONGO_URI=mongodb://mongodb:27017/hr-agent
JWT_SECRET=your-secret-key-change-in-production

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_DEBUG=false
GEMINI_PROMPT_HOT_RELOAD=false

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
CLIENT_URL=http://localhost:5173/login
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.compose https://www.googleapis.com/auth/gmail.send

# Client
VITE_API_URL=http://localhost:5000
